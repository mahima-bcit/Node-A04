<section class="admin-shell">
  <div class="admin-form-header">
    <div>
      <p class="admin-eyebrow">Auth</p>
      <h1>Register</h1>
      <p class="admin-subtitle">Create a new account. Self-registration creates a USER.</p>
    </div>

    <a href="/" class="btn btn-secondary">Back Home</a>
  </div>

  <% if (error) { %>
    <div class="admin-alert admin-alert-error">
      <strong><%= error %></strong>
    </div>
  <% } %>

  <form class="admin-form card" method="POST" action="/auth/register">
    <div class="admin-form-grid">
      <div class="form-field form-field-full">
        <label for="email">Email</label>
        <input
          id="email"
          name="email"
          type="email"
          required
          value="<%= formData?.email || '' %>" />
      </div>

      <div class="form-field form-field-full">
        <label for="nickname">Nickname</label>
        <input
          id="nickname"
          name="nickname"
          type="text"
          required
          value="<%= formData?.nickname || '' %>" />
      </div>

      <div class="form-field form-field-full">
        <label for="password">Password</label>
        <input id="password" name="password" type="password" required />
      </div>
    </div>

    <div class="admin-form-actions">
      <a href="/auth/login" class="btn btn-secondary">Already Have an Account</a>
      <button type="submit" class="btn btn-primary">Register</button>
    </div>
  </form>
</section>