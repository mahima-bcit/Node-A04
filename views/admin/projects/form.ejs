<section class="admin-shell">
  <div class="admin-form-header">
    <div>
      <p class="admin-eyebrow">Admin</p>
      <h1><%= project ? "Edit Project" : "New Project" %></h1>
      <p class="admin-subtitle">
        <%= project ? "Update the project details, upload images, and save your changes." : "Create a new project entry for your portfolio." %>
      </p>
    </div>

    <a href="/admin/projects" class="btn btn-secondary">Back to Projects</a>
  </div>

  <% if (error) { %>
    <div class="admin-alert admin-alert-error">
      <strong><%= error %></strong>
    </div>
  <% } %>

  <form
    class="admin-form card"
    method="POST"
    enctype="multipart/form-data"
    action="<%= project ? '/admin/projects/' + project._id : '/admin/projects' %>"
  >
    <div class="admin-form-grid">
      <div class="form-field">
        <label for="slug">Slug</label>
        <input
          id="slug"
          name="slug"
          type="text"
          required
          value="<%= project?.slug || '' %>"
          placeholder="e.g. personal-portfolio"
        />
      </div>

      <div class="form-field">
        <label for="title">Title</label>
        <input
          id="title"
          name="title"
          type="text"
          required
          value="<%= project?.title || '' %>"
          placeholder="Project title"
        />
      </div>

      <div class="form-field form-field-full">
        <label for="tagline">Tagline</label>
        <input
          id="tagline"
          name="tagline"
          type="text"
          value="<%= project?.tagline || '' %>"
          placeholder="Short one-line summary"
        />
      </div>

      <div class="form-field form-field-full">
        <label for="description">Description</label>
        <textarea
          id="description"
          name="description"
          required
          placeholder="Write a short project description"
        ><%= project?.description || '' %></textarea>
      </div>

      <div class="form-field">
        <label for="categoryId">Category</label>
        <select id="categoryId" name="categoryId" required>
          <% categories.forEach(c => { %>
            <option
              value="<%= c._id %>"
              <%= String(project?.categoryId || "") === String(c._id) ? "selected" : "" %>>
              <%= c.name %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-field">
        <label for="isActive">Visibility</label>
        <select id="isActive" name="isActive">
          <option value="true" <%= project?.isActive === true ? "selected" : "" %>>Active</option>
          <option value="false" <%= project?.isActive === false ? "selected" : "" %>>Inactive</option>
        </select>
      </div>

      <div class="form-field form-field-full">
        <label for="tagsCsv">Tags</label>
        <input
          id="tagsCsv"
          name="tagsCsv"
          type="text"
          required
          value="<%= project?.tagsCsv || '' %>"
          placeholder="crud, api, node"
        />
        <p class="field-help">Comma-separated tags. Example: crud, express, mongodb</p>
      </div>

      <div class="form-field form-field-full">
        <label for="stack">Tech Stack</label>
        <input
          id="stack"
          name="stack"
          type="text"
          value="<%= project?.stackCsv || '' %>"
          placeholder="node, express, mongodb"
        />
        <p class="field-help">Optional. Comma-separated values.</p>
      </div>

      <div class="form-field form-field-full">
        <label for="featuredImage">Featured Image Upload</label>
        <input id="featuredImage" name="featuredImage" type="file" accept="image/*" />
        <p class="field-help">Optional. This will be used as the card thumbnail and project hero.</p>
      </div>

      <div class="form-field form-field-full">
        <label for="galleryImages">Gallery Images Upload</label>
        <input id="galleryImages" name="galleryImages" type="file" accept="image/*" multiple />
        <p class="field-help">Optional. These appear below the project content on the detail page.</p>
      </div>
    </div>

    <div class="admin-form-actions">
      <a href="/admin/projects" class="btn btn-secondary">Cancel</a>
      <button type="submit" class="btn btn-primary">
        <%= project ? "Save Changes" : "Create Project" %>
      </button>
    </div>
  </form>

  <% if (project && project.images && project.images.length) { %>
    <section class="card admin-images-section">
      <h2 class="admin-section-title">Current Images</h2>

      <div class="admin-project-list">
        <% project.images.forEach(function(img, index) { %>
          <article class="admin-project-card card">
            <div class="admin-project-top">
              <div class="admin-project-main">
                <h3 class="admin-project-title">
                  <%= (img.isFeatured || img.type === "cover") ? "Featured Image" : "Gallery Image" %>
                </h3>
                <p class="admin-project-slug"><%= img.path %></p>

                <% if (img.isFeatured || img.type === "cover") { %>
                  <span class="status-badge is-active">Featured</span>
                <% } %>
              </div>

              <div class="admin-project-right">
                <div class="admin-actions">
                  <% if (!(img.isFeatured || img.type === "cover")) { %>
                    <form method="POST" action="/admin/projects/<%= project._id %>/images/<%= index %>/featured">
                      <button type="submit" class="btn btn-secondary">Set Featured</button>
                    </form>
                  <% } %>

                  <form
                    method="POST"
                    action="/admin/projects/<%= project._id %>/images/<%= index %>/delete"
                    onsubmit="return confirm('Delete this image?');">
                    <button type="submit" class="btn btn-danger">Delete Image</button>
                  </form>
                </div>
              </div>
            </div>

            <img
              src="<%= img.path %>"
              alt="<%= img.alt || project.title %>"
              class="admin-image-preview" />
          </article>
        <% }) %>
      </div>
    </section>
  <% } %>
</section>