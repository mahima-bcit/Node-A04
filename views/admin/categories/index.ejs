<section class="admin-shell">
  <div class="admin-toolbar">
    <div>
      <p class="admin-eyebrow">Admin</p>
      <h1>Categories</h1>
      <p class="admin-subtitle">Manage categories and view how many projects reference each one.</p>
    </div>

    <div class="admin-toolbar-actions">
      <a href="/admin" class="btn btn-secondary">Back to Menu</a>
      <a href="/admin/categories/new" class="btn btn-primary">New Category</a>
    </div>
  </div>

  <% if (!categories || !categories.length) { %>
    <div class="admin-empty card">
      <h2>No categories yet</h2>
      <p>Create your first category to organize your projects.</p>
    </div>
  <% } else { %>
    <div class="admin-project-list">
      <% categories.forEach(c => { %>
        <article class="admin-project-card card">
          <div class="admin-project-top">
            <div class="admin-project-main">
              <h2 class="admin-project-title"><%= c.name %></h2>
            </div>

            <div class="admin-project-right">

              <div class="admin-actions">
                <a href="/admin/categories/<%= c._id %>/edit" class="btn btn-secondary">Edit</a>

                <button
                  type="button"
                  class="btn btn-danger"
                  data-delete="/admin/categories/<%= c._id %>"
                  <%= c.projectCount > 0 ? "disabled" : "" %>>
                  Delete
                </button>
              </div>
            </div>
          </div>

          <div class="admin-project-meta">
            <div class="meta-block">
              <span class="meta-label">Description</span>
              <p class="admin-message">
                <%= c.description || "No description added." %>
              </p>
            </div>

            <div class="meta-block">
              <span class="meta-label">Reference Count</span>
              <span class="chip chip-category">
                <%= c.projectCount %> project reference<%= c.projectCount === 1 ? '' : 's' %>
              </span>
            </div>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</section>

<script src="/js/admin.js"></script>