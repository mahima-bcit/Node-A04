<%
  const images = project?.images || [];
  const featuredImage =
    images.find(i => i.isFeatured) ||
    images.find(i => i.type === "cover") ||
    images[0] ||
    null;

  const galleryImages = images.filter((img) => {
    if (!featuredImage) return true;
    return img.path !== featuredImage.path;
  });

  const category = project?.categoryId && typeof project.categoryId === "object" ? project.categoryId : null;
  const tags = (project?.tags || []).map((t) => (typeof t === "string" ? t : t?.name)).filter(Boolean);
%>

<% if (featuredImage) { %>
  <section class="project-detail-hero-wrap">
    <img
      src="<%= featuredImage.path %>"
      alt="<%= featuredImage.alt || project.title %>"
      class="project-detail-hero" />
  </section>
<% } %>

<h1><%= project.title %></h1>

<% if (project.tagline) { %>
  <p><%= project.tagline %></p>
<% } %>

<% if (category) { %>
  <p>
    <strong>Category:</strong>
    <a href="/projects/category/<%= category.slug %>"><%= category.name %></a>
  </p>
<% } %>

<p><%= project.description %></p>

<% if (project.stack && project.stack.length) { %>
  <h3>Tech Stack</h3>
  <div class="pills">
    <% project.stack.forEach(function(s){ %>
      <span><%= s %></span>
    <% }) %>
  </div>
<% } %>

<% if (tags.length) { %>
  <h3>Tags</h3>
  <div class="pills">
    <% tags.forEach(function(t){ %>
      <a class="pill" href="/projects?tag=<%= encodeURIComponent(t) %>"><%= t %></a>
    <% }) %>
  </div>
<% } %>

<% if (galleryImages.length) { %>
  <h3 class="project-gallery-heading">Gallery</h3>
  <div class="project-gallery-grid">
    <% galleryImages.forEach(function(img){ %>
      <img
        src="<%= img.path %>"
        alt="<%= img.alt || project.title %>"
        class="project-gallery-image" />
    <% }) %>
  </div>
<% } %>